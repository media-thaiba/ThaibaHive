# Authentication (REQUIRED in production)
AUTH_JWT_SECRET=change-me-to-a-random-64-char-string

# Cookie domain — leave empty for localhost dev, set to .thaibahive.com for prod
COOKIE_DOMAIN=

# Supabase (optional — currently unused)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=file:./dev.db

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev — comma-separated origins allowed for HMR from other LAN devices
DEV_ORIGINS=192.168.0.136
